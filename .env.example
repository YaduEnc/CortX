# App
APP_NAME=SecondMind API
ENVIRONMENT=development
API_V1_PREFIX=/v1
LOG_LEVEL=INFO

# Security
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
PAIR_TOKEN_TTL_SECONDS=120
PASSWORD_RESET_TOKEN_TTL_SECONDS=900
ADMIN_BOOTSTRAP_KEY=change_this_admin_key

# Database
POSTGRES_USER=secondmind
POSTGRES_PASSWORD=secondmind
POSTGRES_DB=secondmind
DATABASE_URL=postgresql+psycopg2://secondmind:secondmind@postgres:5432/secondmind

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Object Storage (MinIO / S3 compatible)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=secondmind-audio
S3_REGION=us-east-1
S3_USE_SSL=false

# Whisper
WHISPER_MODEL_SIZE=small
# Optional: use a pre-downloaded local model directory (recommended for stable production)
# Example: /models/faster-whisper-small
WHISPER_MODEL_PATH=
# Optional: huggingface cache root
WHISPER_DOWNLOAD_ROOT=/root/.cache/huggingface
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# LM Studio (OpenAI-compatible)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=qwen/qwen2.5-coder-14b
LMSTUDIO_API_KEY=
LMSTUDIO_TIMEOUT_SECONDS=45
LMSTUDIO_TEMPERATURE=0

# Offline TTS
COQUI_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_BACKEND=auto
ESPEAK_VOICE=en-us
ESPEAK_SPEED=165

# Optional cloud TTS. Keep this only in local/server env, never in firmware/app.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=SAz9YHcvj6GT2YYXdXww
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT_SECONDS=45

# Optional Sarvam TTS
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE_CODE=en-IN
SARVAM_TTS_SAMPLE_RATE=24000
SARVAM_TTS_PACE=1.0
SARVAM_TTS_TEMPERATURE=0.6
SARVAM_TTS_TIMEOUT_SECONDS=45

# Upload constraints
MAX_CHUNK_BYTES=768000
MAX_DB_AUDIO_BYTES=5000000
