# App
APP_NAME=SecondMind API
ENVIRONMENT=development
API_V1_PREFIX=/v1
LOG_LEVEL=INFO

# Security
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
PAIR_TOKEN_TTL_SECONDS=120
PASSWORD_RESET_TOKEN_TTL_SECONDS=900
ADMIN_BOOTSTRAP_KEY=change_this_admin_key

# Database
POSTGRES_USER=secondmind
POSTGRES_PASSWORD=secondmind
POSTGRES_DB=secondmind
DATABASE_URL=postgresql+psycopg2://secondmind:secondmind@postgres:5432/secondmind

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Object Storage (MinIO / S3 compatible)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=secondmind-audio
S3_REGION=us-east-1
S3_USE_SSL=false

# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# Upload constraints
MAX_CHUNK_BYTES=768000
MAX_DB_AUDIO_BYTES=5000000
